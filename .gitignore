# =========================
# PocketBase
# =========================
# Ignore live database and runtime data
pocketbase/pb_data/
pocketbase/logs/
pocketbase/*.db

# Keep schema migrations versioned (optional)
!pocketbase/pb_migrations/
!pocketbase/pb_data/.gitkeep

# Ignore PocketBase binary backups
pocketbase/pocketbase_old*
pocketbase/pocketbase.exe
pocketbase/pocketbase-macos
pocketbase/pocketbase-linux
pocketbase/pocketbase-win.exe

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
